generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChannelType {
  PUBLIC
  PRIVATE
  THEME
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String   // bcrypt hash
  photoUrl  String?
  bio       String?
  country   String?
  language  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdChannels Channel[]    @relation("ChannelCreator")
  messages        Message[]
  friendsInitiated Friendship[] @relation("FriendA")
  friendsReceived  Friendship[] @relation("FriendB")
  mutedByMe       Mute[]        @relation("Muter")
  mutedMe         Mute[]        @relation("Muted")
}

model Channel {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  type        ChannelType @default(PUBLIC)
  createdAt   DateTime    @default(now())

  creatorId String?
  creator   User?   @relation("ChannelCreator", fields: [creatorId], references: [id])

  VoiceLog VoiceLog[]
  messages Message[]
}

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  channelId Int
  channel   Channel @relation(fields: [channelId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model Friendship {
  id        String       @id @default(cuid())
  status    FriendStatus @default(PENDING)
  createdAt DateTime     @default(now())

  aId String
  a   User   @relation("FriendA", fields: [aId], references: [id])
  bId String
  b   User   @relation("FriendB", fields: [bId], references: [id])

  @@unique([aId, bId])
}

model VoiceLog {
  id         Int      @id @default(autoincrement())
  userId     String
  userName   String
  durationMs Int
  createdAt  DateTime @default(now())
  channelId  Int
  Channel    Channel  @relation(fields: [channelId], references: [id])
}

model Mute {
  id        String   @id @default(cuid())
  muterId   String   // Quem fez mute
  muter     User     @relation("Muter", fields: [muterId], references: [id], onDelete: Cascade)
  mutedId   String   // Quem foi mutado
  muted     User     @relation("Muted", fields: [mutedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([muterId, mutedId])
}
